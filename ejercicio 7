#include <iostream>
using namespace std;

int main() {
    int numeros[5];
    int *p = numeros;

    for(int i = 0; i < 5; i++) {
        cout << "Numero " << i + 1 << ": ";
        cin >> *(p + i);
    }

    int mayor = *p;

    for(int i = 1; i < 5; i++) {
        if(*(p + i) > mayor)
            mayor = *(p + i);
    }

    cout << "Mayor = " << mayor << endl;

    return 0;
}
