#include <iostream>
using namespace std;

int main() {
    int v[5];
    int *p = v;

    for(int i = 0; i < 5; i++) {
        cout << "Numero " << i + 1 << ": ";
        cin >> *(p + i);
    }

    for(int i = 0; i < 5; i++) {

        for(int j = i + 1; j < 5; j++) {

            if(*(p + i) > *(p + j)) {

                int aux = *(p + i);
                *(p + i) = *(p + j);
                *(p + j) = aux;

            }

        }

    }

    cout << "Arreglo ordenado:" << endl;

    for(int i = 0; i < 5; i++) {
        cout << *(p + i) << " ";
    }

    return 0;
}
