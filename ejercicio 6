#include <iostream>
using namespace std;

int main() {
    int numeros[5];
    int *p = numeros;
    int suma = 0;

    for(int i = 0; i < 5; i++) {
        cout << "Ingrese numero " << i + 1 << ": ";
        cin >> *(p + i);
    }

    for(int i = 0; i < 5; i++) {
        suma += *(p + i);
    }

    cout << "La suma es: " << suma << endl;

    return 0;
}
